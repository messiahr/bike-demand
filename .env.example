# Copy this file to .env and fill in your values.
#
# AWS credentials (access key / secret key) are NOT stored here.
# boto3 reads them from ~/.aws/credentials. Configure that file
# with your [default] profile instead. Install awscli2 and run
# `aws login`.
#
# On Streamlit Cloud, also set these same keys in .streamlit/secrets.toml
# or the app's Secrets UI, along with AWS_ACCESS_KEY_ID and
# AWS_SECRET_ACCESS_KEY.

AWS_BUCKET='bucket_name'
AWS_REGION='us-east-1'
